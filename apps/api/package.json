{
  "name": "@anduck/api",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts | pino-pretty --colorize --ignore pid,hostname",
    "build": "tsc -p tsconfig.json && node scripts/copy-mappers.mjs",
    "prestart": "pnpm run build",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@anduck/types": "workspace:*",
    "@fastify/cors": "^10.0.2",
    "@fastify/jwt": "^9.0.0",
    "@fastify/multipart": "^9.0.1",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/static": "^8.0.3",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "fastify": "^5.2.1",
    "mybatis-mapper": "^0.7.0",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "pino-pretty": "^13.0.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
